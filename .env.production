# ============================================
# 生产环境配置
# ============================================

# --------------------------------------------
# 应用程序配置
# --------------------------------------------
APP_NAME=LunchboxVendingAPI
APP_ENV=production
APP_DEBUG=false
APP_PORT=8080
APP_HOST=0.0.0.0
APP_TIMEZONE=Asia/Shanghai
APP_URL=https://api.yourdomain.com

# Fiber 框架配置
FIBER_PREFORK=true

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=your-production-db-host
DB_PORT=5432
DB_DATABASE=lunchbox_vending_prod
DB_USERNAME=prod_user
DB_PASSWORD=your-secure-password
DB_CHARSET=utf8
DB_SCHEMA=public
DB_SSLMODE=require
DB_TIMEZONE=Asia/Shanghai

# 数据库连接池配置
DB_POOL_MAX_OPEN_CONNS=200
DB_POOL_MAX_IDLE_CONNS=50
DB_POOL_CONN_MAX_LIFETIME=3600
DB_POOL_CONN_MAX_IDLE_TIME=600

# --------------------------------------------
# JWT 认证配置
# --------------------------------------------
JWT_SECRET=your-production-secret-key-change-this
JWT_EXPIRATION_TIME=3600
JWT_REFRESH_TIME=604800
JWT_ISSUER=lunchbox-vending-api

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=your-production-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0

# --------------------------------------------
# 缓存配置
# --------------------------------------------
CACHE_DRIVER=redis
CACHE_PREFIX=lunchbox:prod:
CACHE_DEFAULT_TTL=3600

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_OUTPUT=file
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=10
LOG_COMPRESS=true

# --------------------------------------------
# MinIO 对象存储配置
# --------------------------------------------
MINIO_ENDPOINT=your-minio-endpoint:9000
MINIO_ACCESS_KEY_ID=your-access-key
MINIO_SECRET_ACCESS_KEY=your-secret-key
MINIO_USE_SSL=true
MINIO_BUCKET=lunchbox-media-prod
MINIO_REGION=us-east-1

# --------------------------------------------
# 存储配置
# --------------------------------------------
STORAGE_DRIVER=minio
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,pdf

# --------------------------------------------
# 队列配置
# --------------------------------------------
QUEUE_CONCURRENCY=20
QUEUE_REDIS_ADDR=your-production-redis-host:6379
QUEUE_REDIS_PASSWORD=your-redis-password
QUEUE_REDIS_DB=1

# --------------------------------------------
# 邮件配置
# --------------------------------------------
MAIL_FROM_NAME=Lunchbox Vending
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=your-email-password
MAIL_ENCRYPTION=tls
MAIL_TLS_INSECURE=false

# --------------------------------------------
# WebSocket 配置
# --------------------------------------------
WEBSOCKET_PORT=8081
WEBSOCKET_PATH=/ws
WEBSOCKET_HEARTBEAT_INTERVAL=30

# --------------------------------------------
# 安全配置
# --------------------------------------------
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# --------------------------------------------
# 业务配置
# --------------------------------------------
ORDER_PAYMENT_TIMEOUT=30
ORDER_PICKUP_TIMEOUT=1440
DEVICE_CHANNEL_COUNT=53
DEVICE_CHANNEL_MAX_CAPACITY=4

# --------------------------------------------
# 国际化配置
# --------------------------------------------
I18N_DEFAULT_LANGUAGE=zh-CN
I18N_LANGUAGE_DIR=./lang
I18N_COOKIE_NAME=lang
I18N_COOKIE_MAX_AGE=31536000
