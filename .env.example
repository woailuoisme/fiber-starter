# ============================================
# 饭盒售货机后端 API 系统配置
# ============================================

# --------------------------------------------
# 应用程序配置
# --------------------------------------------
APP_NAME=LunchboxVendingAPI
APP_ENV=local
APP_DEBUG=true
APP_PORT=3000
APP_HOST=0.0.0.0
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:3000

# Fiber 框架配置
# Prefork 模式：启用多进程模式（生产环境建议 true，开发环境 false）
FIBER_PREFORK=false

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=lunchbox_vending
DB_USERNAME=postgres
DB_PASSWORD=
DB_CHARSET=utf8
DB_SCHEMA=public
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# 数据库连接池配置
DB_POOL_MAX_OPEN_CONNS=100
DB_POOL_MAX_IDLE_CONNS=10
DB_POOL_CONN_MAX_LIFETIME=3600
DB_POOL_CONN_MAX_IDLE_TIME=600

# --------------------------------------------
# JWT 认证配置
# --------------------------------------------
JWT_SECRET=your-secret-key-change-in-production-environment
JWT_EXPIRATION_TIME=3600
JWT_REFRESH_TIME=604800
JWT_ISSUER=lunchbox-vending-api

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --------------------------------------------
# 缓存配置
# --------------------------------------------
CACHE_DRIVER=redis
CACHE_PREFIX=lunchbox:
CACHE_DEFAULT_TTL=3600

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_MAX_SIZE=100
LOG_MAX_AGE=30
LOG_MAX_BACKUPS=10
LOG_COMPRESS=true

# --------------------------------------------
# MinIO 对象存储配置
# --------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=lunchbox-media
MINIO_REGION=us-east-1

# --------------------------------------------
# AWS S3 配置 (可选)
# --------------------------------------------
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_BUCKET=lunchbox-media
# S3_ENDPOINT=

# --------------------------------------------
# 存储配置
# --------------------------------------------
STORAGE_DRIVER=minio
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,pdf

# --------------------------------------------
# 队列配置 (Asynq)
# --------------------------------------------
QUEUE_CONCURRENCY=10
QUEUE_REDIS_ADDR=localhost:6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# --------------------------------------------
# 邮件配置
# --------------------------------------------
MAIL_FROM_NAME=Lunchbox Vending
MAIL_FROM_ADDRESS=noreply@lunchbox.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_TLS_INSECURE=false

# --------------------------------------------
# 微信支付配置
# --------------------------------------------
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
WECHAT_NOTIFY_URL=

# --------------------------------------------
# 支付宝配置
# --------------------------------------------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# --------------------------------------------
# WebSocket 配置
# --------------------------------------------
WEBSOCKET_PORT=3001
WEBSOCKET_PATH=/ws
WEBSOCKET_HEARTBEAT_INTERVAL=30

# --------------------------------------------
# 安全配置
# --------------------------------------------
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# --------------------------------------------
# 业务配置
# --------------------------------------------
# 订单超时时间（分钟）
ORDER_PAYMENT_TIMEOUT=30
ORDER_PICKUP_TIMEOUT=1440

# 货道配置
DEVICE_CHANNEL_COUNT=53
DEVICE_CHANNEL_MAX_CAPACITY=4
