# 应用程序配置
APP_NAME=Fiber Starter
APP_PORT=3000
APP_ENV=development
APP_DEBUG=true

# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=
