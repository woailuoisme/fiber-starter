# ============================================
# 开发环境配置
# ============================================

# --------------------------------------------
# 应用程序配置
# --------------------------------------------
APP_NAME=LunchboxVendingAPI
APP_ENV=dev
APP_DEBUG=true
APP_PORT=3000
APP_HOST=0.0.0.0
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost:3000

# Fiber 框架配置
FIBER_PREFORK=false

# --------------------------------------------
# 数据库配置 (PostgreSQL)
# --------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=lunchbox_vending_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_CHARSET=utf8
DB_SCHEMA=public
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai

# 数据库连接池配置
DB_POOL_MAX_OPEN_CONNS=50
DB_POOL_MAX_IDLE_CONNS=10
DB_POOL_CONN_MAX_LIFETIME=3600
DB_POOL_CONN_MAX_IDLE_TIME=600

# --------------------------------------------
# JWT 认证配置
# --------------------------------------------
JWT_SECRET=dev-secret-key-not-for-production
JWT_EXPIRATION_TIME=86400
JWT_REFRESH_TIME=604800
JWT_ISSUER=lunchbox-vending-api

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# --------------------------------------------
# 缓存配置
# --------------------------------------------
CACHE_DRIVER=redis
CACHE_PREFIX=lunchbox:dev:
CACHE_DEFAULT_TTL=3600

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=console
LOG_OUTPUT=stdout
LOG_MAX_SIZE=100
LOG_MAX_AGE=7
LOG_MAX_BACKUPS=3
LOG_COMPRESS=false

# --------------------------------------------
# MinIO 对象存储配置
# --------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=lunchbox-media-dev
MINIO_REGION=us-east-1

# --------------------------------------------
# 存储配置
# --------------------------------------------
STORAGE_DRIVER=minio
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,pdf

# --------------------------------------------
# 队列配置
# --------------------------------------------
QUEUE_CONCURRENCY=5
QUEUE_REDIS_ADDR=localhost:6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# --------------------------------------------
# 邮件配置
# --------------------------------------------
MAIL_FROM_NAME=Lunchbox Vending Dev
MAIL_FROM_ADDRESS=dev@localhost
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_TLS_INSECURE=true

# --------------------------------------------
# WebSocket 配置
# --------------------------------------------
WEBSOCKET_PORT=3001
WEBSOCKET_PATH=/ws
WEBSOCKET_HEARTBEAT_INTERVAL=30

# --------------------------------------------
# 安全配置
# --------------------------------------------
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60

# --------------------------------------------
# 业务配置
# --------------------------------------------
ORDER_PAYMENT_TIMEOUT=30
ORDER_PICKUP_TIMEOUT=1440
DEVICE_CHANNEL_COUNT=53
DEVICE_CHANNEL_MAX_CAPACITY=4

# --------------------------------------------
# 国际化配置
# --------------------------------------------
I18N_DEFAULT_LANGUAGE=zh-CN
I18N_LANGUAGE_DIR=./lang
I18N_COOKIE_NAME=lang
I18N_COOKIE_MAX_AGE=31536000
