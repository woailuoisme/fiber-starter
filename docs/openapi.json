{
  "components": {
    "schemas": {
      "ChangePasswordRequest": {
        "properties": {
          "current_password": {
            "type": "string"
          },
          "new_password": {
            "type": "string"
          }
        },
        "required": [
          "current_password",
          "new_password"
        ],
        "type": "object"
      },
      "LoginRequest": {
        "properties": {
          "email": {
            "format": "email",
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ],
        "type": "object"
      },
      "RefreshTokenRequest": {
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        },
        "required": [
          "refresh_token"
        ],
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "email": {
            "format": "email",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ],
        "type": "object"
      },
      "ResetPasswordRequest": {
        "properties": {
          "email": {
            "format": "email",
            "type": "string"
          }
        },
        "required": [
          "email"
        ],
        "type": "object"
      },
      "UpdateProfileRequest": {
        "properties": {
          "avatar": {
            "format": "uri",
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          }
        },
        "type": "object"
      }
    }
  },
  "info": {
    "description": "OpenAPI 3.1 contract for the Fiber Starter backend.",
    "title": "Fiber Starter API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "Service landing page"
      }
    },
    "/api/v1/auth/change-password": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Password changed"
          }
        },
        "summary": "Change password"
      }
    },
    "/api/v1/auth/login": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Logged in"
          }
        },
        "summary": "Login"
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "responses": {
          "200": {
            "description": "Logged out"
          }
        },
        "summary": "Logout"
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Tokens refreshed"
          }
        },
        "summary": "Refresh JWT tokens"
      }
    },
    "/api/v1/auth/register": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "User registered"
          }
        },
        "summary": "Register a new user"
      }
    },
    "/api/v1/auth/reset-password": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ResetPasswordRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Reset email sent or password updated"
          }
        },
        "summary": "Reset password"
      }
    },
    "/api/v1/users/": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "List users"
      }
    },
    "/api/v1/users/me": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "Current user profile"
      }
    },
    "/api/v1/users/profile": {
      "put": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          }
        },
        "summary": "Update current user profile"
      }
    },
    "/api/v1/users/search": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "Search users"
      }
    },
    "/api/v1/users/{id}": {
      "delete": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          }
        },
        "summary": "Delete user"
      },
      "put": {
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "format": "int64",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User updated"
          }
        },
        "summary": "Update user"
      }
    },
    "/docs": {
      "get": {
        "responses": {
          "200": {
            "description": "Scalar UI"
          }
        },
        "summary": "Scalar API reference"
      }
    },
    "/health": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "Health check"
      }
    },
    "/openapi.json": {
      "get": {
        "responses": {
          "200": {
            "description": "OpenAPI 3.1 JSON document"
          }
        },
        "summary": "OpenAPI document"
      }
    },
    "/ready": {
      "get": {
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "summary": "Readiness probe"
      }
    }
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ]
}
